# Copy to `.env` and fill in real values (never commit real `.env` to Git).
# Restart the backend after edits: Ctrl+C then `npm run dev`

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/book_your_artist
JWT_SECRET=change_this_to_a_long_random_string

STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ---------------------------------------------------------------------------
# Email (SMTP) — used for payout OTP via email (preferred channel).
# Gmail: turn on 2-Step Verification, then generate an App Password at
# https://myaccount.google.com/apppasswords  and use it as SMTP_PASS.
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Book Your Artist <noreply@bookyourartist.local>

# ---------------------------------------------------------------------------
# SMS providers for artist payout OTP (optional — email is enough on its own).
# Priority: Notify.lk → Text.lk → Twilio.
# ---------------------------------------------------------------------------

# Notify.lk (recommended for Sri Lanka, free trial credits)
# https://app.notify.lk/  → Dashboard → Settings → API
NOTIFY_LK_USER_ID=
NOTIFY_LK_API_KEY=
NOTIFY_LK_SENDER_ID=NotifyDEMO

# Text.lk (Sri Lankan alternative)
# https://app.text.lk/
TEXT_LK_API_TOKEN=
TEXT_LK_SENDER_ID=TextLKDemo

# Twilio (international fallback)
# https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

SMS_DEFAULT_COUNTRY_CODE=+94

# ---------------------------------------------------------------------------
# Firebase — must match ONE web app under Firebase Console → Project settings
# Use either (A) one JSON blob OR (B) individual variables below.
# Frontend must use same project: NEXT_PUBLIC_FIREBASE_* in frontend/.env.local
# Firebase Console checklist:
# - Authentication → Sign-in method → Google → Enable
# - Authentication → Settings → Authorized domains → add localhost / your deployed host
# ---------------------------------------------------------------------------

# (A) Optional: paste the whole web config object as ONE LINE of JSON:
# FIREBASE_WEB_CONFIG_JSON={"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}

# (B) Individual vars (recommended for simpler .env editing):
FIREBASE_WEB_API_KEY=
FIREBASE_PROJECT_ID=
# Optional — if empty, defaults to PROJECT_ID.firebaseapp.com and PROJECT_ID.appspot.com
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Fallback for local tooling only (normally leave blank on the server)
NEXT_PUBLIC_FIREBASE_API_KEY=

# Optional secrets file alongside .env — copy firebase-web-client.json.example
# backend/firebase-web-client.json — gitignored — same fields as Firebase web snippet JSON
